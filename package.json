{
  "name": "eve",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo run dev --filter=dashboard",
    "dev:main": "turbo run dev --filter=main-agent",
    "dev:project": "turbo run dev --filter=project-agent",
    "eve:dev:headless": "turbo run dev:headless",
    "agents:dev": "agents-dev",
    "agents:json": "agents-json --out apps/dashboard",
    "typecheck": "turbo typecheck",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@clerk/eve-auth": "workspace:*",
    "@types/node": "24.x",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "turbo": "^2.3.0"
  },
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "resolutions": {
    "ai": "7.0.0-beta.178"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@clerk/shared",
    "esbuild",
    "sharp",
    "unrs-resolver"
  ],
  "engines": {
    "node": "24.x"
  }
}
