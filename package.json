{
  "name": "eve",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo run dev --filter=dashboard",
    "dev:agent": "turbo run dev --filter=main-agent",
    "eve:dev:headless": "turbo run dev:headless",
    "typecheck": "turbo typecheck",
    "lint": "biome check",
    "format": "biome format --write",
    "gen:agent": "turbo gen agent"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@turbo/gen": "^2.3.0",
    "@types/inquirer-autocomplete-prompt": "^3.0.3",
    "@types/node": "24.x",
    "@typescript/native-preview": "7.0.0-dev.20260523.1",
    "inquirer-autocomplete-prompt": "^3.0.1",
    "turbo": "^2.3.0"
  },
  "overrides": {
    "ai": "7.0.0-beta.178"
  },
  "resolutions": {
    "ai": "7.0.0-beta.178"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "@clerk/shared",
    "esbuild",
    "sharp",
    "unrs-resolver"
  ],
  "engines": {
    "node": "24.x"
  }
}
