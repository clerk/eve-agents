{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "CLERK_SECRET_KEY",
    "CLERK_PUBLISHABLE_KEY",
    "CLERK_MACHINE_SECRET_KEY",
    "AI_GATEWAY_API_KEY",
    "NEXT_PUBLIC_*"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        ".eve/**",
        ".output/**",
        ".vercel/output/**",
        ".next/**",
        "!.next/cache/**"
      ]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "dev:headless": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
